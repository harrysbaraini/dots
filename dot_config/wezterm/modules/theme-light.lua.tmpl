{{- $t := .theme.light -}}
-- Theme: {{ $t.name }}
-- Auto-generated by chezmoi — do not edit directly.
-- Edit colors in .chezmoi.toml.tmpl instead.

local M = {}

M.colors = {
	foreground = "{{ $t.fg }}",
	background = "{{ $t.bg }}",

	cursor_bg = "{{ $t.cursor }}",
	cursor_fg = "{{ $t.bg }}",
	cursor_border = "{{ $t.cursor }}",

	selection_bg = "{{ $t.bg_selection }}",
	selection_fg = "{{ $t.fg }}",

	scrollbar_thumb = "{{ $t.bg_surface }}",
	split = "{{ $t.border }}",

	ansi = {
		"{{ $t.ansi_black }}",
		"{{ $t.ansi_red }}",
		"{{ $t.ansi_green }}",
		"{{ $t.ansi_yellow }}",
		"{{ $t.ansi_blue }}",
		"{{ $t.ansi_magenta }}",
		"{{ $t.ansi_cyan }}",
		"{{ $t.ansi_white }}",
	},

	brights = {
		"{{ $t.bright_black }}",
		"{{ $t.bright_red }}",
		"{{ $t.bright_green }}",
		"{{ $t.bright_yellow }}",
		"{{ $t.bright_blue }}",
		"{{ $t.bright_magenta }}",
		"{{ $t.bright_cyan }}",
		"{{ $t.bright_white }}",
	},

	tab_bar = {
		background = "{{ $t.bg_secondary }}",

		active_tab = {
			bg_color = "{{ $t.bg_selection }}",
			fg_color = "{{ $t.fg }}",
			intensity = "Bold",
			underline = "Single",
		},

		inactive_tab = {
			bg_color = "{{ $t.bg }}",
			fg_color = "{{ $t.fg_secondary }}",
		},

		inactive_tab_hover = {
			bg_color = "{{ $t.bg_selection }}",
			fg_color = "{{ $t.fg }}",
			italic = false,
		},

		new_tab = {
			bg_color = "{{ $t.bg_secondary }}",
			fg_color = "{{ $t.fg_secondary }}",
		},

		new_tab_hover = {
			bg_color = "{{ $t.bg_selection }}",
			fg_color = "{{ $t.fg }}",
		},
	},
}

function M.apply_to_config(config)
	config.colors = M.colors
	config.window_background_opacity = 1.0
	config.window_padding = {
		left = 12,
		right = 12,
		top = 8,
		bottom = 8,
	}
	config.use_fancy_tab_bar = true
	config.hide_tab_bar_if_only_one_tab = false
	config.tab_bar_at_bottom = false
	config.window_frame = {
		font_size = 12.0,
		active_titlebar_bg = "{{ $t.bg_secondary }}",
		inactive_titlebar_bg = "{{ $t.bg_secondary }}",
	}
	config.inactive_pane_hsb = {
		saturation = 0.85,
		brightness = 0.7,
	}
end

return M
