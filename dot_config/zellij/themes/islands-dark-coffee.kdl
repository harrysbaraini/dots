// Islands Relax Dark Coffee - Complete Zellij Theme
// Based on the JetBrains Islands Relax Dark Coffee theme by Panxiaoan
//
// Place in your zellij config.kdl or import it.
// Set: theme "islands-dark-coffee"
//
// Color palette reference:
//   primaryBg:    44  33  34  (#2C2122)
//   secondaryBg:  32  19  21  (#201315)
//   mainBg:       60  48  49  (#3c3031)
//   selection:   110  69  82  (#6E4552)
//   fg:          187 187 187  (#BBBBBB)
//   gold:        219 171  74  (#DBAB4A)  - accent
//   rose:        169 111 121  (#A96F79)  - underline
//   red:         255  85  84  (#ff5554)
//   green:        47 200 100  (#2fc864)
//   blue:         93 163 244  (#5da3f4)
//   purple:      189 147 249  (#bd93f9)
//   pink:        255 121 198  (#ff79c6)
//   cyan:        139 233 253  (#8be9fd)

themes {
    islands_dark_coffee {
        text_unselected {
            base 187 187 187
            background 44 33 34
            emphasis_0 219 171 74
            emphasis_1 93 163 244
            emphasis_2 47 200 100
            emphasis_3 189 147 249
