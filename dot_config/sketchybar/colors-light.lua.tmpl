{{- $t := .theme.light -}}
-- Theme: {{ $t.name }}
-- Auto-generated by chezmoi — do not edit directly.
-- Edit colors in .chezmoi.toml.tmpl instead.
-- All colors are 0xAARRGGBB format

local colors = {
  -- Base surfaces
  bg_base    = 0x{{ $t.bar_alpha }}{{ trimPrefix "#" $t.bg }},
  bg_surface = 0x{{ $t.surface_alpha }}{{ trimPrefix "#" $t.bg_surface }},
  bg_overlay = 0xff{{ trimPrefix "#" $t.bg_selection }},

  -- Accent colors
  wave_blue     = 0xff{{ trimPrefix "#" $t.ansi_blue }},
  spring_violet = 0xff{{ trimPrefix "#" $t.ansi_magenta }},
  autumn_red    = 0xff{{ trimPrefix "#" $t.ansi_red }},
  wave_aqua     = 0xff{{ trimPrefix "#" $t.bright_blue }},
  spring_green  = 0xff{{ trimPrefix "#" $t.ansi_green }},
  autumn_yellow = 0xff{{ trimPrefix "#" $t.ansi_yellow }},
  sakura_pink   = 0xff{{ trimPrefix "#" $t.bright_magenta }},
  old_white     = 0xff{{ trimPrefix "#" $t.bright_white }},

  -- Text
  fg_primary   = 0xff{{ trimPrefix "#" $t.fg }},
  fg_secondary = 0xff{{ trimPrefix "#" $t.fg_secondary }},
  fg_dim       = 0xff{{ trimPrefix "#" $t.fg_muted }},

  -- Transparent
  transparent  = 0x00000000,

  -- Module backgrounds / borders (with alpha baked in)
  module_bg     = 0x{{ $t.surface_alpha }}{{ trimPrefix "#" $t.bg_surface }},
  module_border = 0x40{{ trimPrefix "#" $t.accent }},

  -- Workspace accent colors (one per slot, cycling)
  workspace_accents = {
    0xff{{ trimPrefix "#" $t.ansi_magenta }}, -- 1: purple
    0xff{{ trimPrefix "#" $t.ansi_green }},   -- 2: green
    0xff{{ trimPrefix "#" $t.ansi_yellow }},  -- 3: gold
    0xff{{ trimPrefix "#" $t.bright_blue }},  -- 4: light blue
    0xff{{ trimPrefix "#" $t.ansi_blue }},    -- 5: blue
    0xff{{ trimPrefix "#" $t.ansi_red }},     -- 6: red
  },

  -- Blend alpha (0.0–1.0) into a 0xAARRGGBB color
  with_alpha = function(color, alpha)
    if alpha == nil or alpha > 1.0 or alpha < 0.0 then return color end
    return (color & 0x00ffffff) | (math.floor(alpha * 255.0) << 24)
  end,
}

return colors
