{{- $t := .theme.dark -}}
{{- /* Convert hex colors to "R G B" decimal triplets */ -}}
{{- $hexList := list (trimPrefix "#" $t.bg) (trimPrefix "#" $t.bg_surface) (trimPrefix "#" $t.bg_selection) (trimPrefix "#" $t.fg) (trimPrefix "#" $t.fg_secondary) (trimPrefix "#" $t.border) (trimPrefix "#" $t.accent) (trimPrefix "#" $t.ansi_red) (trimPrefix "#" $t.ansi_green) (trimPrefix "#" $t.ansi_blue) (trimPrefix "#" $t.ansi_magenta) (trimPrefix "#" $t.bright_blue) -}}
{{- $rgbCmd := printf "for h in %s; do printf '%%d %%d %%d\\n' 0x${h:0:2} 0x${h:2:2} 0x${h:4:2}; done" (join " " $hexList) -}}
{{- $rgbAll := output "bash" "-c" $rgbCmd | trim -}}
{{- $rgb := splitList "\n" $rgbAll -}}
{{- $bg := index $rgb 0 -}}
{{- $surface := index $rgb 1 -}}
{{- $selection := index $rgb 2 -}}
{{- $fg := index $rgb 3 -}}
{{- $fg2 := index $rgb 4 -}}
{{- $border := index $rgb 5 -}}
{{- $accent := index $rgb 6 -}}
{{- $red := index $rgb 7 -}}
{{- $green := index $rgb 8 -}}
{{- $blue := index $rgb 9 -}}
{{- $magenta := index $rgb 10 -}}
{{- $bblue := index $rgb 11 -}}
